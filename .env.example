# Server-side Supabase settings. Do not ship the service role key in Android.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PLANNER_SESSION_SECRET=

# Android share API settings. The app calls this API with an existing app session token.
PLANNER_API_BASE_URL=http://localhost:3000
PLANNER_SESSION_PREFS_NAME=planner_auth
PLANNER_SESSION_TOKEN_KEY=session_token
VITE_PLANNER_API_BASE_URL=http://localhost:3000

# Debug builds do not require release signing or Google Play values.
ANDROID_APPLICATION_ID=com.lss.onmyplate.nativeplanner
ANDROID_VERSION_CODE=1
ANDROID_VERSION_NAME=0.1.0

# Gemini appointment parser configuration.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-27b-it
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Required only for signed release builds and Play publishing.
# Android signing keystore (.jks) absolute path
ANDROID_KEYSTORE_PATH=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=

# Required only for Play publishing.
PLAY_SERVICE_ACCOUNT_JSON_PATH=
PLAY_TRACK=internal
PLAY_RELEASE_STATUS=DRAFT
